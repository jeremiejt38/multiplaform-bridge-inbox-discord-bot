# Example .env for multibridhe-inbox-discord-bot

# .env.example
# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ADMIN_ID=

# Telegram
TELEGRAM_TOKEN=

# WhatsApp: no token (QR at first run)
# WhatsApp (QR-based session)
# No token — QR scan on first run

# Instagram
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Facebook
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=

# Snapchat
SNAPCHAT_USERNAME=
SNAPCHAT_PASSWORD=

# TikTok
TIKTOK_USERNAME=
TIKTOK_PASSWORD=

# Database
DATABASE_PATH=./data/bot.db
